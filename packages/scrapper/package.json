{
  "name": "scrapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --localstorage-file=../../.localstorage --import tsx/esm src/main.ts",
    "dev": "node --watch --localstorage-file=../../.localstorage --import tsx/esm src/main.ts",
    "migrate": "pnpm -F @ai-tg-channels/migrations migrate",
    "install-types": "tdl-install-types prebuilt-tdlib",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@ai-tg-channels/migrations": "workspace:*",
    "@ai-tg-channels/models": "workspace:*",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "prebuilt-tdlib": "latest",
    "sequelize": "^6.37.8",
    "tdl": "^8.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "tdl@8.1.0": true
  }
}